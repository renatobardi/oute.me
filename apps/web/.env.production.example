# ============================================================
# apps/web — Produção (configurar no Cloud Run, não commitar preenchido)
# Bucket GCS: oute-prod-uploads (automático via ENVIRONMENT=production)
# Auth: ADC via Service Account do Cloud Run
# ============================================================

DATABASE_URL=postgresql://postgres:PASSWORD@/oute_production?host=/cloudsql/oute-488706:us-central1:oute-prod

FIREBASE_PROJECT_ID=oute-488706
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXX@oute-488706.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=oute-488706.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=oute-488706

PUBLIC_GOOGLE_CLIENT_ID=

AI_SERVICE_URL=https://oute-ai-prod-HASH.run.app

ADMIN_EMAILS=admin@oute.pro

ENVIRONMENT=production
