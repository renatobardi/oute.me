# ============================================================
# apps/web — Variáveis de ambiente
# Ver .env.development.example e .env.production.example
# para configurações completas por ambiente.
# ============================================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/oute_develop

# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (público, exposto ao browser)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=

# Google Identity Services — One Tap
PUBLIC_GOOGLE_CLIENT_ID=

# AI Service (interno)
AI_SERVICE_URL=http://localhost:8000

# Admin — lista de e-mails separados por vírgula que recebem is_admin=true automaticamente no primeiro login
ADMIN_EMAILS=seuemail@dominio.com

# Ambiente — development | production
# Define qual bucket GCS é usado automaticamente:
#   development → oute-dev-uploads
#   production  → oute-prod-uploads
ENVIRONMENT=development

# Storage — GCS (Google Cloud Storage)
# Autenticação via ADC. Em dev local: gcloud auth application-default login
# Para sobrescrever o bucket padrão do ambiente:
# GOOGLE_CLOUD_STORAGE_BUCKET=meu-bucket-customizado

# Upload — tamanho máximo de request (bytes). 50 MB para suportar documentos grandes.
# Nota: Cloud Run tem limite de 32 MB por request em produção.
# Em produção, manter 32 MB (33554432) para respeitar o limite da plataforma.
BODY_SIZE_LIMIT=52428800
