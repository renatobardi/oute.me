# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/oute_develop

# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (public, exposed to browser)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=

# AI Service (internal)
AI_SERVICE_URL=http://localhost:8000

# Admin — lista de e-mails separados por vírgula que recebem is_admin=true automaticamente no primeiro login
ADMIN_EMAILS=seuemail@dominio.com

# Google Identity Services — One Tap
# Google Cloud Console > APIs & Services > Credenciais > OAuth 2.0 > Client ID (Web)
# Mesmo client ID já usado pelo Firebase para login com Google
# Adicionar oute.me e localhost:5173 em "Origens JavaScript autorizadas"
PUBLIC_GOOGLE_CLIENT_ID=
